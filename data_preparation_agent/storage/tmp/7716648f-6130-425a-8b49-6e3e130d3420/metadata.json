{
  "business_rules": [
    "Each contract must belong to only one client",
    "Invoice numbers must be unique",
    "Policy start date must be earlier than policy end date",
    "Coverage days must correspond to the difference between start and end dates",
    "Dataset must not contain duplicate rows",
    "Prime amount must correspond to the insured contract coverage"
  ],

  "columns": [
    {
      "column_name": "Num_facture",
      "business_name": "Invoice Number",
      "type": "int",
      "nullable": false,
      "identifier": true,
      "min": 1,
      "description": "Unique invoice number"
    },

    {
      "column_name": "num_contrat",
      "business_name": "Contract Number",
      "type": "int",
      "nullable": false,
      "identifier": false,
      "min": 1,
      "description": "Insurance contract identifier"
    },

    {
      "column_name": "exe",
      "business_name": "Fiscal Year",
      "type": "int",
      "nullable": false,
      "min": 2000,
      "max": 2100,
      "description": "Accounting year of the invoice"
    },

    {
      "column_name": "dtemi",
      "business_name": "Invoice Emission Date",
      "type": "date",
      "nullable": false,
      "format": "MM/DD/YYYY",
      "description": "Date when the invoice was issued"
    },

    {
      "column_name": "datedeb",
      "business_name": "Coverage Start Date",
      "type": "date",
      "nullable": false,
      "format": "MM/DD/YYYY",
      "description": "Beginning of insurance coverage"
    },

    {
      "column_name": "datefin",
      "business_name": "Coverage End Date",
      "type": "date",
      "nullable": false,
      "format": "MM/DD/YYYY",
      "description": "End of insurance coverage"
    },

    {
      "column_name": "datcpt",
      "business_name": "Accounting Date",
      "type": "date",
      "nullable": false,
      "format": "MM/DD/YYYY",
      "description": "Accounting booking date"
    },

    {
      "column_name": "libop",
      "business_name": "Operation Label",
      "type": "string",
      "nullable": false,
      "enum": ["Avenant", "Emission", "Annulation"],
      "description": "Type of operation related to the invoice"
    },

    {
      "column_name": "ncli",
      "business_name": "Client Number",
      "type": "int",
      "nullable": false,
      "identifier": false,
      "min": 1,
      "description": "Unique client identifier"
    },

    {
      "column_name": "Prime",
      "business_name": "Premium Amount",
      "type": "float",
      "nullable": false,
      "min": 0,
      "max": 1000000,
      "description": "Insurance premium paid by the client"
    },

    {
      "column_name": "nomncli",
      "business_name": "Client Name",
      "type": "string",
      "nullable": false,
      "pattern": "^client_[0-9]+$",
      "description": "Client display name"
    },

    {
      "column_name": "nb_jour_couv",
      "business_name": "Coverage Days",
      "type": "int",
      "nullable": false,
      "min": 1,
      "max": 3650,
      "description": "Number of coverage days for the policy"
    },

    {
      "column_name": "client_age",
      "business_name": "Client Age",
      "type": "int",
      "nullable": false,
      "min": 18,
      "max": 100,
      "description": "Age of the insured client"
    },

    {
      "column_name": "client_gender",
      "business_name": "Client Gender",
      "type": "string",
      "nullable": false,
      "enum": ["Male", "Female"],
      "description": "Gender of the client"
    },

    {
      "column_name": "client_marital_status",
      "business_name": "Client Marital Status",
      "type": "string",
      "nullable": false,
      "enum": ["Single", "Married", "Divorced", "Widowed"],
      "description": "Marital status of the client"
    }
  ]
}