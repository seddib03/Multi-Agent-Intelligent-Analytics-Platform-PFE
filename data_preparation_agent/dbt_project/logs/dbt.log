    as (
      
    
  








    



with row_groups as (
    select
        Num_facture, num_contrat, exe, dtemi, datedeb, datefin, datcpt, libop, ncli, Prime, nomncli, nb_jour_couv, client_age, client_gender, client_marital_status,
        count(*) as __dup_count,
        min(__row_id) as __kept_row_id
    from "db"."main"."raw_data"
    group by Num_facture, num_contrat, exe, dtemi, datedeb, datefin, datcpt, libop, ncli, Prime, nomncli, nb_jour_couv, client_age, client_gender, client_marital_status
    having count(*) > 1
)

select 
    src.__row_id,
    
    src.Num_facture,
    
    src.num_contrat,
    
    src.exe,
    
    src.dtemi,
    
    src.datedeb,
    
    src.datefin,
    
    src.datcpt,
    
    src.libop,
    
    src.ncli,
    
    src.Prime,
    
    src.nomncli,
    
    src.nb_jour_couv,
    
    src.client_age,
    
    src.client_gender,
    
    src.client_marital_status
    
from "db"."main"."raw_data" src
inner join row_groups rg
    on 
        (src.Num_facture = rg.Num_facture or (src.Num_facture is null and rg.Num_facture is null))
