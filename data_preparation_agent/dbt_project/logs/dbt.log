         and 
    
        (src.Prime = rg.Prime or (src.Prime is null and rg.Prime is null))
         and 
    
        (src.nomncli = rg.nomncli or (src.nomncli is null and rg.nomncli is null))
         and 
    
        (src.nb_jour_couv = rg.nb_jour_couv or (src.nb_jour_couv is null and rg.nb_jour_couv is null))
         and 
    
        (src.client_age = rg.client_age or (src.client_age is null and rg.client_age is null))
         and 
    
