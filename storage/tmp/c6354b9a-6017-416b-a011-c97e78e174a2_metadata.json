{
    "sector": "retail",
    "version": "1.0",
    "columns": [
        {
            "name": "transaction_id",
            "type": "string",
            "role": "identifier",
            "nullable": false
        },
        {
            "name": "revenue",
            "type": "float",
            "role": "metric",
            "nullable": false,
            "range": {"min": 0, "max": 1000000},
            "extensions": {"unit": "USD", "kpi_name": "CA"}
        },
        {
            "name": "store_id",
            "type": "string",
            "role": "dimension",
            "nullable": true,
            "pattern": "^STR-[0-9]{4}$"
        },
        {
            "name": "sale_date",
            "type": "date",
            "role": "temporal_key",
            "nullable": false,
            "date_format": "%Y-%m-%d"
        }
    ],
    "sector_config": {"currency": "USD"}
}