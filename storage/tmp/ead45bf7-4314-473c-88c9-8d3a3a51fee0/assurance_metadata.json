{
    "sector": "assurance",
    "version": "1.0",
    "columns": [
        {
            "name": "contrat_id",
            "type": "string",
            "role": "identifier",
            "nullable": false,
            "pattern": "^CTR-[0-9]{6}$"
        },
        {
            "name": "prime_annuelle",
            "type": "float",
            "role": "metric",
            "nullable": false,
            "range": {"min": 100, "max": 50000},
            "extensions": {
                "unit": "EUR",
                "kpi_name": "Prime annuelle",
                "agregation": "sum"
            }
        },
        {
            "name": "montant_sinistre",
            "type": "float",
            "role": "metric",
            "nullable": true,
            "range": {"min": 0, "max": 500000},
            "extensions": {
                "unit": "EUR",
                "kpi_name": "Montant sinistre"
            }
        },
        {
            "name": "client_id",
            "type": "string",
            "role": "dimension",
            "nullable": false,
            "pattern": "^CLI-[0-9]{5}$"
        },
        {
            "name": "type_contrat",
            "type": "string",
            "role": "dimension",
            "nullable": false
        },
        {
            "name": "date_effet",
            "type": "date",
            "role": "temporal_key",
            "nullable": false,
            "date_format": "%Y-%m-%d",
            "business_rule": "date_effet doit etre avant date_echeance"
        },
        {
            "name": "date_echeance",
            "type": "date",
            "role": "temporal_key",
            "nullable": false,
            "date_format": "%Y-%m-%d"
        }
    ],
    "sector_config": {
        "devise": "EUR",
        "regulateur": "ACPR",
        "exercice": "annuel",
        "marche": "France"
    }
}