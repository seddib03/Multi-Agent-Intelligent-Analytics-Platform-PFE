[
    {
  "column_name": "transaction_id",
  "type": "string",
  "identifier": true,
  "pattern": "^[0-9]{6}$",
  "description": "Transaction ID — exactly 6 digits"
    },
    {
    "column_name": "store_id",
    "type": "string",
    "pattern": "^[0-9]{1,3}$",
    "description": "Store ID — 1 to 3 digits"
    },
    {
    "column_name":"product_category",
    "type":"string",
    "enum":["Electronics","Clothing","Food","Furniture"]
    },
    {
    "column_name":"price",
    "type":"float",
    "min":10000,
    "max":20000
    },
    {
    "column_name":"quantity",
    "type":"int",
    "min":1,
    "max":100
    },
    {
    "column_name":"transaction_date",
    "type":"date",
    "format":"YYYY-MM-DD"
    },
    {
    "column_name":"payment_method",
    "type":"string",
    "enum":["Cash","Card","Online"]
    }
]