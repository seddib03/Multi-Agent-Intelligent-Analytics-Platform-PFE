{
  "template_name": "operational_dashboard",
  "description": "Operational dashboard template with KPI cards and multiple analytical charts",
  "layout": {
    "header": {
      "enabled": true,
      "title_placeholder": "Dashboard Title"
    },
    "kpi_section": {
      "enabled": true,
      "slots": 3,
      "layout": "horizontal"
    },
    "main_chart_section": {
      "enabled": false,
      "slots": 0,
      "preferred_types": []
    },
    "secondary_chart_section": {
      "enabled": true,
      "slots": 4,
      "layout": "grid",
      "preferred_types": ["bar", "column", "pie", "scatter", "histogram"]
    },
    "insights_section": {
      "enabled": true,
      "slots": 2
    },
    "filters_section": {
      "enabled": true,
      "suggested_filters": ["category", "segment", "status"]
    }
  },
  "selection_rules": {
    "min_kpis": 2,
    "max_kpis": 3,
    "requires_trend_chart": false,
    "max_total_charts": 4
  }
}
