{
  "template_name": "executive_dashboard",
  "description": "Executive dashboard template with KPI cards, one main trend chart, and two secondary charts",
  "layout": {
    "header": {
      "enabled": true,
      "title_placeholder": "Dashboard Title"
    },
    "kpi_section": {
      "enabled": true,
      "slots": 4,
      "layout": "horizontal"
    },
    "main_chart_section": {
      "enabled": true,
      "slots": 1,
      "preferred_types": ["line", "area"]
    },
    "secondary_chart_section": {
      "enabled": true,
      "slots": 2,
      "layout": "horizontal",
      "preferred_types": ["bar", "pie", "column"]
    },
    "insights_section": {
      "enabled": true,
      "slots": 3
    },
    "filters_section": {
      "enabled": true,
      "suggested_filters": ["time", "category", "segment"]
    }
  },
  "selection_rules": {
    "min_kpis": 3,
    "max_kpis": 4,
    "requires_trend_chart": true,
    "max_total_charts": 3
  }
}
