    {
      "name": "4 — Multi-User Sessions",
      "item": [
        {
          "name": "4.1 User A — première question (history=1)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_A\",\n  \"question\": \"Quel est le On-Time Performance ce mois ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200',         () => pm.response.to.have.status(200));",
            "pm.test('user_id = user_A',   () => pm.expect(pm.response.json().user_id).to.eql('user_A'));",
            "pm.test('history_length = 1', () => pm.expect(pm.response.json().history_length).to.eql(1));",
            "console.log('User A | Turn 1 | history:', pm.response.json().history_length);"
          ]}}]
        },
        {
          "name": "4.2 User B — session indépendante (history=1 ≠ A)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_B\",\n  \"question\": \"Montre-moi le taux d'annulation\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200',         () => pm.response.to.have.status(200));",
            "pm.test('user_id = user_B',   () => pm.expect(pm.response.json().user_id).to.eql('user_B'));",
            "pm.test('history_length = 1 (isolated)', () => pm.expect(pm.response.json().history_length).to.eql(1));",
            "console.log('User B | Turn 1 | history:', pm.response.json().history_length, '← isolated from A ✅');"
          ]}}]
        },
        {
          "name": "4.3 User A — deuxième question (history=2, B reste à 1)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_A\",\n  \"question\": \"Et pour le mois dernier ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200',         () => pm.response.to.have.status(200));",
            "pm.test('history_length = 2', () => pm.expect(pm.response.json().history_length).to.eql(2));",
            "console.log('User A | Turn 2 | history:', pm.response.json().history_length, '← User B still at 1 ✅');"
          ]}}]
        }
      ]
    },

    {
      "name": "5 — Reset Session",
      "item": [
        {
          "name": "5.1 Reset user_demo_001",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat/reset",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('history_cleared true', () => pm.expect(b.history_cleared).to.be.true);",
            "pm.test('message present',      () => pm.expect(b.message).to.not.be.empty);",
            "console.log('✅ Reset | cleared:', b.history_cleared);"
          ]}}]
        },
        {
          "name": "5.2 Vérif reset — history repart à 1",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"question\": \"Quel est le Load Factor moyen ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200',         () => pm.response.to.have.status(200));",
            "pm.test('history_length = 1', () => pm.expect(pm.response.json().history_length).to.eql(1));",
            "console.log('✅ Post-reset | history:', pm.response.json().history_length, '← fresh start');"
          ]}}]
        },
        {
          "name": "5.3 Reset session inexistante — history_cleared=false",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat/reset",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_qui_nexiste_pas\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200',             () => pm.response.to.have.status(200));",
            "pm.test('history_cleared false',   () => pm.expect(pm.response.json().history_cleared).to.be.false);",
            "pm.test('no error',               () => pm.expect(pm.response.json()).to.not.have.property('detail'));",
            "console.log('✅ Non-existing session | cleared:', pm.response.json().history_cleared);"
          ]}}]
        }
      ]
    },

