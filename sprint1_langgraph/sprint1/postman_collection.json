{
  "info": {
    "name": "DXC Intelligence Analytics — Sprint 1 (Architecture Complète)",
    "description": "Collection complète alignée sur l'architecture DXC.\n\n## Table de routing\n\n| Intent | Agent | Orchestrateur |\n|---|---|---|\n| sql, aggregation, comparison, explanation | NLQ direct | NON |\n| prediction, anomaly | Generic Predictive Agent | OUI |\n| sector_analysis | Sector Specific Agent | OUI |\n| dashboard, kpi_chart, insight | Insight Agent | OUI |\n\n## Ordre d'exécution\n1. Health Check\n2. Detect Sector (5 cas)\n3. NLQ Direct (4 intents)\n4. Routing Orchestrateur (6 intents)\n5. Multi-User Sessions\n6. Reset\n7. Error Handling",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url",       "value": "http://localhost:8000"},
    {"key": "sector_context", "value": ""},
    {"key": "user_id",        "value": "user_demo_001"}
  ],
  "item": [

    {
      "name": "0 — Health Check",
      "item": [{
        "name": "0.1 API Status",
        "request": {"method": "GET", "url": "{{base_url}}/health"},
        "event": [{"listen": "test", "script": {"exec": [
          "pm.test('Status 200', () => pm.response.to.have.status(200));",
          "const b = pm.response.json();",
          "pm.test('status ok',    () => pm.expect(b.status).to.eql('ok'));",
          "pm.test('model llama',  () => pm.expect(b.model).to.include('llama'));",
          "pm.test('sessions num', () => pm.expect(b.active_sessions).to.be.a('number'));",
          "console.log('API OK | Model:', b.model);"
        ]}}]
      }]
    },

    {
      "name": "1 — Detect Sector",
      "item": [
        {
          "name": "1.1 Transport — query précise",
          "request": {
            "method": "POST", "url": "{{base_url}}/detect-sector",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_query\": \"améliorer l'expérience des passagers de l'aéroport de Casablanca\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('sector transport',    () => pm.expect(b.sector).to.eql('transport'));",
            "pm.test('routing_target',      () => pm.expect(b.routing_target).to.eql('transport_agent'));",
            "pm.test('confidence >= 0.85',  () => pm.expect(b.confidence).to.be.at.least(0.85));",
            "pm.test('metadata_used false', () => pm.expect(b.metadata_used).to.be.false);",
            "pm.test('kpis 3-5',            () => pm.expect(b.kpis.length).to.be.within(3,5));",
            "pm.collectionVariables.set('sector_context', JSON.stringify(b));",
            "console.log('✅ Transport | conf:', b.confidence, '| KPIs:', b.kpis.map(k=>k.name).join(', '));"
          ]}}]
        },
        {
          "name": "1.2 Query ambiguë SANS colonnes — confiance basse",
          "request": {
            "method": "POST", "url": "{{base_url}}/detect-sector",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_query\": \"améliorer l'expérience client\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('sector detected',    () => pm.expect(b.sector).to.not.be.empty);",
            "pm.test('confidence < 0.85',  () => pm.expect(b.confidence).to.be.below(0.85));",
            "pm.test('metadata false',     () => pm.expect(b.metadata_used).to.be.false);",
            "console.log('⚠️  Ambiguous | sector:', b.sector, '| conf:', b.confidence);"
          ]}}]
        },
        {
          "name": "1.3 Query ambiguë AVEC colonnes — confiance haute ↑",
          "request": {
            "method": "POST", "url": "{{base_url}}/detect-sector",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_query\": \"améliorer l'expérience client\",\n  \"column_metadata\": [\n    {\"name\": \"flight_id\",        \"description\": \"ID du vol\",              \"sample_values\": [\"AT101\",\"AT202\"]},\n    {\"name\": \"delay_minutes\",    \"description\": \"Retard en minutes\",      \"sample_values\": [\"0\",\"15\",\"45\"]},\n    {\"name\": \"route\",           \"description\": \"Route aérienne\",          \"sample_values\": [\"CMN-CDG\",\"CMN-MAD\"]},\n    {\"name\": \"passenger_count\", \"description\": \"Passagers\"},\n    {\"name\": \"satisfaction_score\", \"description\": \"Score satisfaction\",   \"sample_values\": [\"3.2\",\"4.1\"]}\n  ]\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('sector transport',     () => pm.expect(b.sector).to.eql('transport'));",
            "pm.test('confidence >= 0.88',   () => pm.expect(b.confidence).to.be.at.least(0.88));",
            "pm.test('metadata_used TRUE',   () => pm.expect(b.metadata_used).to.be.true);",
            "pm.collectionVariables.set('sector_context', JSON.stringify(b));",
            "console.log('✅ Colonnes → conf:', b.confidence, '| metadata_used:', b.metadata_used);"
          ]}}]
        },
        {
          "name": "1.4 Finance — détection",
          "request": {
            "method": "POST", "url": "{{base_url}}/detect-sector",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_query\": \"analyser la performance financière et réduire les risques de défaut de crédit\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('sector finance',            () => pm.expect(b.sector).to.eql('finance'));",
            "pm.test('routing finance_agent',     () => pm.expect(b.routing_target).to.eql('finance_agent'));",
            "console.log('✅ Finance | KPIs:', b.kpis.map(k=>k.name).join(', '));"
          ]}}]
        },
        {
          "name": "1.5 Manufacturing — détection",
          "request": {
            "method": "POST", "url": "{{base_url}}/detect-sector",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_query\": \"optimiser la production et réduire les défauts qualité en usine\"\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('sector manufacturing',      () => pm.expect(b.sector).to.eql('manufacturing'));",
            "pm.test('routing manufacturing',     () => pm.expect(b.routing_target).to.eql('manufacturing_agent'));",
            "console.log('✅ Manufacturing | KPIs:', b.kpis.map(k=>k.name).join(', '));"
          ]}}]
        }
      ]
    },

    {
      "name": "2 — NLQ Direct (4 intents)",
      "item": [
        {
          "name": "2.1 aggregation — retard moyen (SQL + KPI)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"question\": \"Quel est le taux de retard moyen ce mois ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('requires_orchestrator FALSE', () => pm.expect(b.requires_orchestrator).to.be.false);",
            "pm.test('routing_target null',         () => pm.expect(b.routing_target).to.be.null);",
            "pm.test('intent aggregation',          () => pm.expect(b.intent).to.eql('aggregation'));",
            "pm.test('SQL generated',               () => pm.expect(b.generated_query).to.include('SELECT'));",
            "pm.test('kpi_referenced present',      () => pm.expect(b.kpi_referenced).to.not.be.empty);",
            "pm.test('history_length = 1',          () => pm.expect(b.history_length).to.eql(1));",
            "console.log('✅ NLQ direct | aggregation | SQL:', b.generated_query?.substring(0,60));"
          ]}}]
        },
        {
          "name": "2.2 comparison — routes aériennes (history=2)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"question\": \"Compare les performances CMN-CDG vs CMN-MAD en termes de retard\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('requires_orchestrator FALSE', () => pm.expect(b.requires_orchestrator).to.be.false);",
            "pm.test('intent comparison',           () => pm.expect(b.intent).to.eql('comparison'));",
            "pm.test('history_length = 2',          () => pm.expect(b.history_length).to.eql(2));",
            "console.log('✅ NLQ direct | comparison | history:', b.history_length);"
          ]}}]
        },
        {
          "name": "2.3 follow-up — question de suivi (history=3)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"question\": \"Et pour la route CMN-LHR spécifiquement ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('requires_orchestrator FALSE', () => pm.expect(b.requires_orchestrator).to.be.false);",
            "pm.test('history_length = 3',          () => pm.expect(b.history_length).to.eql(3));",
            "console.log('✅ Follow-up | history:', b.history_length);"
          ]}}]
        },
        {
          "name": "2.4 sql — liste de vols avec data_profile (SQL = vrais noms colonnes)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"question\": \"Liste les 10 vols avec le plus grand retard ce mois\",\n  \"sector_context\": {{sector_context}},\n  \"data_profile\": {\n    \"row_count\": 1500,\n    \"columns\": [\"flight_id\",\"route\",\"departure_date\",\"delay_minutes\",\"gate\",\"passenger_count\",\"satisfaction_score\",\"status\"],\n    \"numeric_columns\": [\"delay_minutes\",\"passenger_count\",\"satisfaction_score\"],\n    \"categorical_columns\": [\"route\",\"gate\",\"status\"],\n    \"datetime_columns\": [\"departure_date\"],\n    \"missing_summary\": {\"gate\": 2.1},\n    \"quality_score\": 87.5\n  }\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('requires_orchestrator FALSE', () => pm.expect(b.requires_orchestrator).to.be.false);",
            "pm.test('SQL uses real column names',   () => pm.expect(b.generated_query?.toLowerCase()).to.satisfy(",
            "  s => s && (s.includes('delay_minutes') || s.includes('flight_id'))",
            "));",
            "pm.test('history_length = 4',           () => pm.expect(b.history_length).to.eql(4));",
            "console.log('✅ SQL avec data_profile | colonnes réelles:', b.generated_query?.substring(0,80));"
          ]}}]
        }
      ]
    },

    {
      "name": "3 — Routing Orchestrateur (6 intents)",
      "item": [
        {
          "name": "3.1 prediction → generic_predictive_agent (history inchangé)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"question\": \"Prédis le taux de retard moyen pour le mois prochain\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('requires_orchestrator TRUE',       () => pm.expect(b.requires_orchestrator).to.be.true);",
            "pm.test('routing generic_predictive_agent', () => pm.expect(b.routing_target).to.eql('generic_predictive_agent'));",
            "pm.test('intent prediction',                () => pm.expect(b.intent).to.eql('prediction'));",
            "pm.test('payload.task_type = prediction',   () => pm.expect(b.orchestrator_payload.task_type).to.eql('prediction'));",
            "pm.test('history unchanged = 4',            () => pm.expect(b.history_length).to.eql(4));",
            "pm.test('payload.sector correct',           () => pm.expect(b.orchestrator_payload.sector).to.eql('transport'));",
            "console.log('🔀 PREDICTION → generic_predictive_agent');",
            "console.log('   payload:', JSON.stringify(b.orchestrator_payload));"
          ]}}]
        },
