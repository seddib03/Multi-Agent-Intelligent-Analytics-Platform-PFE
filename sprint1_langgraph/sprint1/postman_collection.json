            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_sector_test\",\n  \"question\": \"Génère un rapport complet de performance du secteur transport ce trimestre\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{"listen": "test", "script": {"exec": [
