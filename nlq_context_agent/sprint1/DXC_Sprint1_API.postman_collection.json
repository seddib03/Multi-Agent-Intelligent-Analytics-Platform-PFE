    {
      "name": "6 — Multi-User Sessions",
      "item": [
        {
          "name": "6.1 User A — question directe",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_A\",\n  \"question\": \"Quel est le On-Time Performance ce mois ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200',        () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('user_id = user_A',  () => pm.expect(b.user_id).to.eql('user_A'));",
              "pm.test('history = 1',       () => pm.expect(b.history_length).to.eql(1));",
              "console.log('User A | Turn 1 | history:', b.history_length);"
            ]}
          }]
        },
        {
          "name": "6.2 User B — session indépendante",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_B\",\n  \"question\": \"Montre-moi le taux d'annulation\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200',        () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('user_id = user_B',  () => pm.expect(b.user_id).to.eql('user_B'));",
              "pm.test('history = 1',       () => pm.expect(b.history_length).to.eql(1));",
              "console.log('User B | Turn 1 | history:', b.history_length, '← isolated from A ✅');"
            ]}
          }]
        },
        {
          "name": "6.3 User A — routing vers insight_agent (history inchangé)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_A\",\n  \"question\": \"Génère le dashboard KPI complet\",\n  \"sector_context\": {{sector_context}}\n}"},
            "description": "Routé → history doit rester à 1."
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200',                () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('requires_orchestrator=TRUE', () => pm.expect(b.requires_orchestrator).to.be.true);",
              "pm.test('routing=insight_agent',      () => pm.expect(b.routing_target).to.eql('insight_agent'));",
              "pm.test('history = 1 (unchanged)',    () => pm.expect(b.history_length).to.eql(1));",
              "console.log('User A | Routed to insight | history:', b.history_length, '← should be 1');"
            ]}
          }]
        },
        {
          "name": "6.4 User A — nouvelle question directe (history=2)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_A\",\n  \"question\": \"Et le taux d'annulation moyen ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200',        () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('history = 2',       () => pm.expect(b.history_length).to.eql(2));",
              "console.log('User A | Turn 2 (direct after routed) | history:', b.history_length, '← 2 ✅');"
            ]}
          }]
        }
      ]
    },

    {
      "name": "7 — Reset Session",
      "item": [
        {
          "name": "7.1 Reset user_demo_001",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat/reset",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\"\n}"}
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200',            () => pm.response.to.have.status(200));",
              "const b = pm.response.json();",
              "pm.test('history_cleared=true',  () => pm.expect(b.history_cleared).to.be.true);",
              "pm.test('user_id correct',        () => pm.expect(b.user_id).to.eql(pm.collectionVariables.get('user_id')));",
              "console.log('✅ Reset OK | user:', b.user_id);"
            ]}
          }]
        },
        {
          "name": "7.2 Vérifier reset → history=1",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"question\": \"Quel est le Load Factor moyen ?\",\n  \"sector_context\": {{sector_context}}\n}"}
          },
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Status 200',    () => pm.response.to.have.status(200));",
              "pm.test('history = 1',   () => pm.expect(pm.response.json().history_length).to.eql(1));",
              "console.log('✅ Post-reset | history=1 (fresh start)');"
            ]}
          }]
        },
        {
          "name": "7.3 Reset session inexistante (history_cleared=false)",
          "request": {
            "method": "POST", "url": "{{base_url}}/chat/reset",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"user_id\": \"user_fantome_123\"\n}"}
          },
          "event": [{
            "listen": "test",
